# Environment variables template
# Copy this file to .env and update values as needed

# Application Settings
PROJECT_NAME=Votuna API
DEBUG=False

# CORS - allowed origins (can be JSON array or comma-separated list)
# Examples:
#   ALLOWED_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000","http://localhost:8080"]
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Database credentials (used by Docker Compose for PostgreSQL)
DB_USER=votuna_user
DB_PASSWORD=votuna_password
DB_NAME=votuna
DB_PORT=5432

# Database Configuration (REQUIRED - must be a valid PostgreSQL URL)
# Format: postgresql://username:password@host:port/database
# For Docker Compose: postgresql://${DB_USER}:${DB_PASSWORD}@postgres:${DB_PORT}/${DB_NAME}
# For local development: postgresql://votuna_user:votuna_password@localhost:5432/votuna
DATABASE_URL=postgresql://votuna_user:votuna_password@postgres:5432/votuna

# SQLAlchemy logging (set to True to see SQL queries)
SQLALCHEMY_ECHO=False

# API configuration
API_PORT=8000

# Auth (SSO + JWT)
# Spotify app settings (set in Spotify Developer Dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback/spotify
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token

# SoundCloud app settings
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback/soundcloud
SOUNDCLOUD_API_BASE_URL=https://api.soundcloud.com
SOUNDCLOUD_TOKEN_URL=https://secure.soundcloud.com/oauth/token

# TIDAL app settings
TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback/tidal
TIDAL_API_BASE_URL=https://openapi.tidal.com/v2
TIDAL_TOKEN_URL=https://auth.tidal.com/v1/oauth2/token
TIDAL_COUNTRY_CODE=

# Apple Sign In (REQUIRED for /api/v1/auth/login/apple)
# APPLE_CLIENT_ID: Apple OAuth client_id (usually your Services ID for web login)
APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET: JWT client secret for Sign in with Apple.
# Generate/update with CLI args only:
# python scripts/generate_apple_tokens.py --token-type client-secret --team-id ... --key-id ... --client-id ... --private-key-path ... --write-env
APPLE_CLIENT_SECRET=
# For local Apple Sign In testing, use your reserved ngrok domain and register
# this exact callback URL in Apple Developer > Sign In with Apple.
# Example: APPLE_REDIRECT_URI=https://my-fixed-domain.ngrok-free.app/api/v1/auth/callback/apple
APPLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/callback/apple

# Apple Music Kit (REQUIRED for Apple provider playlist/track features in this app)
# Required: APPLE_MUSIC_TEAM_ID, APPLE_MUSIC_KEY_ID, APPLE_MUSIC_PRIVATE_KEY.
# These are used to mint Apple Music developer tokens at runtime.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
APPLE_MUSIC_PRIVATE_KEY=

# Apple Music API settings
# APPLE_MUSIC_DEVELOPER_TOKEN is optional override. Leave empty to use runtime
# generation from APPLE_MUSIC_TEAM_ID/APPLE_MUSIC_KEY_ID/APPLE_MUSIC_PRIVATE_KEY.
# To generate/update a static token via script:
# python scripts/generate_apple_tokens.py --token-type music-developer --team-id ... --key-id ... --private-key-path ... --write-env
APPLE_MUSIC_DEVELOPER_TOKEN=
APPLE_MUSIC_DEVELOPER_TOKEN_TTL_SECONDS=15777000
# Required storefront used for Apple catalog API calls (default shown for US).
APPLE_MUSIC_STOREFRONT=us
APPLE_MUSIC_API_BASE_URL=https://api.music.apple.com

# JWT settings
AUTH_SECRET_KEY=change-me
AUTH_TOKEN_EXPIRE_MINUTES=10080
AUTH_COOKIE_NAME=votuna_access_token
# For local frontend(http://localhost:3000) + API(https://<ngrok-domain>) testing:
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=lax
FRONTEND_URL=http://localhost:3000

# User file storage (relative to api/ when running in Docker)
USER_FILES_DIR=user_files
MAX_AVATAR_BYTES=5242880

# Frontend configuration
FRONTEND_PORT=3000
# API URL accessible from the browser (use localhost for local development)
# For Apple local testing via fixed ngrok domain set NEXT_PUBLIC_API_URL=https://<reserved-ngrok-domain>
NEXT_PUBLIC_API_URL=http://localhost:8000

# -----------------------------
# Railway production deployment
# -----------------------------
# These are examples for Railway service variables (set in Railway UI, not committed .env files).
#
# API service:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# AUTH_SECRET_KEY=<strong-random-value>
# AUTH_COOKIE_SECURE=True
# AUTH_COOKIE_SAMESITE=lax
# FRONTEND_URL=https://<frontend-domain>.up.railway.app
# ALLOWED_ORIGINS=["https://<frontend-domain>.up.railway.app"]
# SOUNDCLOUD_REDIRECT_URI=https://<api-domain>.up.railway.app/api/v1/auth/callback/soundcloud
# USER_FILES_DIR=/app/user_files
# RAILWAY_RUN_UID=0
#
# Frontend service:
# NEXT_PUBLIC_API_URL=https://<api-domain>.up.railway.app
#
# Cookie guidance:
# - Use AUTH_COOKIE_SAMESITE=lax when frontend and API are on the same site.
# - Use AUTH_COOKIE_SAMESITE=none only for true cross-site deployments and keep AUTH_COOKIE_SECURE=True.
